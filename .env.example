# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Azure Database for PostgreSQL Flexible Server connection variables.
# You can either provide a full connection string:
DATABASE_URL="postgresql://user:password@host.postgres.database.azure.com:5432/dbname?sslmode=require"

# Azure Database for PostgreSQL Flexible Server connection variables:
AZURE_PG_HOST="host.postgres.database.azure.com"
AZURE_PG_USER="username"
AZURE_PG_PASSWORD="password"
AZURE_PG_DATABASE="dbname"
AZURE_PG_PORT="5432"
AZURE_PG_SSL="true"

# Azure Blob Storage Account variables:
# 1. Connection string of the storage account
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=your_account_name;AccountKey=your_account_key;EndpointSuffix=core.windows.net"
# 2. Container name to upload images (will be created automatically if it doesn't exist)
AZURE_STORAGE_CONTAINER_NAME="dojastore"

# Paystack API Keys:
# Configure these in the platform's Secrets settings panel to run live production/test checkouts.
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# Facebook/Meta Pixel Tracking:
VITE_FACEBOOK_PIXEL_ID=
VITE_FACEBOOK_CONVERSION_ID=

